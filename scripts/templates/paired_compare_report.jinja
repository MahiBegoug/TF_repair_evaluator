<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TFRepair Paired Docs vs Snippet Report</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/default.min.css">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/highlight.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/languages/diff.min.js"></script>
    <style>
        :root {
            --bg: #f4f6f8;
            --panel: #ffffff;
            --panel-alt: #f8fafc;
            --border: #d7dde5;
            --ink: #1f2933;
            --muted: #52606d;
            --accent: #1f6feb;
            --docs: #fff6ea;
            --snippet: #edf7ed;
            --success: #1a7f37;
            --danger: #cf222e;
            --warning: #9a6700;
            --neutral: #57606a;
        }

        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
            background: var(--bg);
            color: var(--ink);
        }

        .controls {
            position: sticky;
            top: 0;
            z-index: 10;
            display: flex;
            gap: 16px;
            align-items: center;
            flex-wrap: wrap;
            padding: 14px 20px;
            background: rgba(255, 255, 255, 0.96);
            border-bottom: 1px solid var(--border);
            backdrop-filter: blur(10px);
        }

        .controls label {
            font-size: 14px;
            font-weight: 600;
        }

        .controls select,
        .controls button {
            padding: 8px 12px;
            border: 1px solid var(--border);
            border-radius: 8px;
            background: white;
            font: inherit;
        }

        .summary {
            margin-left: auto;
            font-size: 13px;
            color: var(--muted);
        }

        .page {
            max-width: 1580px;
            margin: 0 auto;
            padding: 24px;
        }

        h1 {
            margin: 0 0 8px;
            font-size: 28px;
        }

        .intro {
            margin: 0 0 24px;
            color: var(--muted);
        }

        .case {
            background: var(--panel);
            border: 1px solid var(--border);
            border-radius: 16px;
            box-shadow: 0 8px 24px rgba(15, 23, 42, 0.06);
            padding: 20px;
            margin-bottom: 24px;
        }

        .case-header {
            display: flex;
            justify-content: space-between;
            gap: 16px;
            align-items: start;
            margin-bottom: 14px;
        }

        .case-header h2 {
            margin: 0;
            font-size: 20px;
        }

        .case-header a {
            color: inherit;
            text-decoration: none;
        }

        .case-header a:hover {
            color: var(--accent);
        }

        .case-id {
            white-space: nowrap;
            color: var(--muted);
            font-size: 13px;
        }

        .meta {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            margin-bottom: 18px;
        }

        .pill {
            padding: 6px 10px;
            border-radius: 999px;
            background: var(--panel-alt);
            border: 1px solid var(--border);
            font-size: 12px;
            color: var(--muted);
        }

        .pair-grid {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 18px;
        }

        .variant {
            border: 1px solid var(--border);
            border-radius: 14px;
            overflow: hidden;
            background: white;
        }

        .variant.docs {
            background: var(--docs);
        }

        .variant.snippet {
            background: var(--snippet);
        }

        .variant-head {
            padding: 14px 16px;
            border-bottom: 1px solid var(--border);
            display: flex;
            justify-content: space-between;
            gap: 12px;
            align-items: baseline;
        }

        .variant-title {
            font-size: 18px;
            font-weight: 700;
        }

        .variant-subtitle {
            color: var(--muted);
            font-size: 13px;
        }

        .variant-body {
            padding: 16px;
            background: white;
        }

        .status {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            margin-bottom: 12px;
        }

        .badge {
            display: inline-block;
            padding: 4px 10px;
            border-radius: 999px;
            font-size: 12px;
            font-weight: 700;
        }

        .ok {
            background: rgba(26, 127, 55, 0.12);
            color: var(--success);
        }

        .bad {
            background: rgba(207, 34, 46, 0.12);
            color: var(--danger);
        }

        .warn {
            background: rgba(154, 103, 0, 0.14);
            color: var(--warning);
        }

        .neutral {
            background: rgba(87, 96, 106, 0.12);
            color: var(--neutral);
        }

        .variant dl {
            display: grid;
            grid-template-columns: 120px 1fr;
            gap: 8px 12px;
            margin: 0 0 16px;
            font-size: 14px;
        }

        .variant dt {
            color: var(--muted);
            font-weight: 600;
        }

        .variant dd {
            margin: 0;
        }

        .section-title {
            margin: 18px 0 8px;
            font-size: 13px;
            text-transform: uppercase;
            letter-spacing: 0.06em;
            color: var(--muted);
        }

        pre {
            margin: 0;
            padding: 10px 12px;
            background: #f6f8fa;
            border: 1px solid var(--border);
            border-radius: 10px;
            overflow-x: auto;
            font-size: 12px;
        }

        pre code .line {
            display: block;
        }

        pre code .line::before {
            content: attr(data-line-nums) " | ";
            display: inline-block;
            min-width: 6em;
            padding-right: 1em;
            color: #6e7781;
            user-select: none;
        }

        pre code .line.hunk-header::before {
            content: "";
            min-width: 0;
            padding-right: 0;
        }

        details {
            margin-top: 12px;
        }

        summary {
            cursor: pointer;
            color: var(--accent);
            font-weight: 600;
        }

        .compare {
            margin-top: 18px;
            border-top: 1px solid var(--border);
            padding-top: 18px;
        }

        @media (max-width: 1100px) {
            .pair-grid {
                grid-template-columns: 1fr;
            }

            .summary {
                width: 100%;
                margin-left: 0;
            }
        }
    </style>
</head>
<body>
    {% macro status_badges(row, mode) -%}
        <div class="status">
            {% if row %}
                {% if row.is_fixed %}
                    <span class="badge ok">fixed</span>
                {% else %}
                    <span class="badge bad">not fixed</span>
                {% endif %}
                {% if row.line_specific_error_fixed %}
                    <span class="badge ok">target error fixed</span>
                {% else %}
                    <span class="badge bad">target error persists</span>
                {% endif %}
                {% if row.line_is_clean %}
                    <span class="badge ok">line clean</span>
                {% else %}
                    <span class="badge warn">line not clean</span>
                {% endif %}
                {% set new_errors = row.module_fix_introduced_errors|default(0) %}
                {% if new_errors > 0 %}
                    <span class="badge bad">{{ new_errors }} new module errors</span>
                {% else %}
                    <span class="badge ok">no new module errors</span>
                {% endif %}
                {% set block_errors = row.block_fix_introduced_errors|default(0) %}
                {% if block_errors > 0 %}
                    <span class="badge warn">{{ block_errors }} new block errors</span>
                {% endif %}
                {% set ghost_errors = row.module_original_errors_remaining|default(0) %}
                {% if ghost_errors > 0 %}
                    <span class="badge neutral">{{ ghost_errors }} remaining original module errors</span>
                {% endif %}
            {% else %}
                <span class="badge neutral">{{ mode }} row missing</span>
            {% endif %}
        </div>
    {%- endmacro %}

    {% macro variant_panel(label, row, css_class) -%}
        <section class="variant {{ css_class }}">
            <div class="variant-head">
                <div>
                    <div class="variant-title">{{ label }}</div>
                    {% if row %}
                        <div class="variant-subtitle">{{ row.llm_name }}</div>
                    {% endif %}
                </div>
            </div>
            <div class="variant-body">
                {{ status_badges(row, label|lower) }}
                {% if row %}
                    <dl>
                        <dt>Input OID</dt>
                        <dd>{{ row.oid[:12] if row.oid else "-" }}</dd>
                        <dt>Baseline OID</dt>
                        <dd>{{ row.oid_result[:12] if row.oid_result else "-" }}</dd>
                        <dt>Specific OID</dt>
                        <dd>{{ row.specific_oid }}</dd>
                    </dl>

                    <div class="section-title">Patch diff against original block</div>
                    {% if row.diff %}
                        <pre><code class="language-diff">{{ row.diff|safe }}</code></pre>
                    {% else %}
                        <pre><code>No diff generated</code></pre>
                    {% endif %}

                    <details>
                        <summary>Show original and modified block content</summary>
                        <div class="section-title">Original</div>
                        <pre><code class="language-hcl">{{ row.original_content|e }}</code></pre>
                        <div class="section-title">Modified</div>
                        <pre><code class="language-hcl">{{ row.modified_content|e }}</code></pre>
                    </details>

                    <details>
                        <summary>Show raw LLM output</summary>
                        <pre><code>{{ row.raw_llm_output|e }}</code></pre>
                    </details>
                {% endif %}
            </div>
        </section>
    {%- endmacro %}

    <div class="controls">
        <label for="model-filter">Model</label>
        <select id="model-filter" onchange="filterCases()">
            <option value="all">All models</option>
            {% for model in all_models %}
                <option value="{{ model }}">{{ model }}</option>
            {% endfor %}
        </select>

        <label for="iteration-filter">Iteration</label>
        <select id="iteration-filter" onchange="filterCases()">
            <option value="all">All iterations</option>
            {% for iteration in all_iterations %}
                <option value="{{ iteration }}">{{ iteration }}</option>
            {% endfor %}
        </select>

        <button type="button" onclick="resetFilters()">Reset</button>
        <div id="case-summary" class="summary"></div>
    </div>

    <main class="page">
        <h1>Docs fail / snippet succeed</h1>
        <p class="intro">
            Paired comparison view. Each card shows one shared instance for the same model family and iteration, with the
            docs-augmented result on the left and the snippet-only result on the right.
        </p>

        {% for case in cases %}
            <article class="case" data-model="{{ case.model_family }}" data-iteration="{{ case.iteration_id }}">
                <div class="case-header">
                    <div>
                        <h2 id="{{ case.case_id }}">
                            <a href="#{{ case.case_id }}">{{ case.project_name }}/{{ case.filename }}</a>
                        </h2>
                        <div class="variant-subtitle">{{ case.summary }}</div>
                    </div>
                    <div class="case-id">
                        model={{ case.model_family }}<br>
                        iter={{ case.iteration_id }}<br>
                        specific_oid={{ case.specific_oid }}
                    </div>
                </div>

                <div class="meta">
                    <span class="pill">lines {{ case.line_start }}-{{ case.line_end }}</span>
                    <span class="pill">severity {{ case.severity }}</span>
                    {% if case.provider_name %}<span class="pill">provider {{ case.provider_name }}</span>{% endif %}
                    {% if case.block_type %}<span class="pill">block {{ case.block_type }}</span>{% endif %}
                    {% if case.problem_category %}<span class="pill">category {{ case.problem_category }}</span>{% endif %}
                    {% if case.problem_class %}<span class="pill">class {{ case.problem_class }}</span>{% endif %}
                    {% if case.metrics_depth == case.metrics_depth %}<span class="pill">depth {{ case.metrics_depth }}</span>{% endif %}
                    {% if case.metrics_loc == case.metrics_loc %}<span class="pill">loc {{ case.metrics_loc }}</span>{% endif %}
                    {% if case.metrics_nloc == case.metrics_nloc %}<span class="pill">nloc {{ case.metrics_nloc }}</span>{% endif %}
                </div>

                {% if case.original_problem_summary or case.original_problem_detail %}
                    <details>
                        <summary>Show benchmark problem description</summary>
                        {% if case.original_problem_summary %}
                            <div class="section-title">Summary</div>
                            <div>{{ case.original_problem_summary }}</div>
                        {% endif %}
                        {% if case.original_problem_detail %}
                            <div class="section-title">Detail</div>
                            <div>{{ case.original_problem_detail }}</div>
                        {% endif %}
                    </details>
                {% endif %}

                <div class="pair-grid">
                    {{ variant_panel("Documentation prompt", case.docs, "docs") }}
                    {{ variant_panel("Snippet-only prompt", case.snippet, "snippet") }}
                </div>

                <div class="compare">
                    <details>
                        <summary>Show direct diff between docs fix and snippet fix</summary>
                        {% if case.pair_diff %}
                            <pre><code class="language-diff">{{ case.pair_diff|safe }}</code></pre>
                        {% else %}
                            <pre><code>No diff generated between docs and snippet outputs</code></pre>
                        {% endif %}
                    </details>
                </div>
            </article>
        {% endfor %}
    </main>

    <script>
        hljs.highlightAll();

        function updateSummary() {
            const visible = Array.from(document.querySelectorAll('.case')).filter(
                (node) => node.style.display !== 'none'
            ).length;
            const total = document.querySelectorAll('.case').length;
            document.getElementById('case-summary').textContent = `${visible} / ${total} cases shown`;
        }

        function filterCases() {
            const model = document.getElementById('model-filter').value;
            const iteration = document.getElementById('iteration-filter').value;
            document.querySelectorAll('.case').forEach((node) => {
                const modelMatch = model === 'all' || node.dataset.model === model;
                const iterMatch = iteration === 'all' || node.dataset.iteration === iteration;
                node.style.display = modelMatch && iterMatch ? '' : 'none';
            });
            updateSummary();
        }

        function resetFilters() {
            document.getElementById('model-filter').value = 'all';
            document.getElementById('iteration-filter').value = 'all';
            filterCases();
        }

        updateSummary();
    </script>
</body>
</html>
